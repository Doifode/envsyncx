{
  "name": "envsyncx",
  "version": "1.0.0",
  "description": "Local CLI tool for managing .env profiles — save, switch, diff, audit and protect environment variables without committing secrets.",
  "main": "./dist/index.js",
  "bin": {
    "esync": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/index.ts"
